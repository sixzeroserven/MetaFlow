LOGIN_URL=https://www.facebook.com/login
LOGIN_USERNAME=your_email_or_phone
LOGIN_PASSWORD=your_password

USERNAME_SELECTOR=input[name="email"]
PASSWORD_SELECTOR=input[name="pass"]

# The default script submits with Enter after filling the password.
# Set CLICK_LOGIN_BUTTON=true if you want to click this selector instead.
SUBMIT_SELECTOR=div[role="button"][aria-label="登录"]
CLICK_LOGIN_BUTTON=false

# Optional: set this to an element that only appears after login.
# SUCCESS_SELECTOR=

# Optional: reuse browser state/cookies after a manual verification.
# CHROME_PROFILE_DIR=./chrome-profile
CHROME_ATTACH_EXISTING=true
# Optional for Docker/Linux Chrome.
# CHROME_BINARY=/usr/bin/chromium
# CHROME_EXTRA_ARGS=--no-sandbox||--disable-dev-shm-usage||--disable-gpu||--window-size=1440,1100

# Optional: choose a login account from accounts.json.
# Command line --account takes priority over ACCOUNT_NAME.
ACCOUNTS_FILE=accounts.json
# ACCOUNT_NAME=main

SELENIUM_TIMEOUT=20
KEEP_BROWSER_OPEN=true
HEADLESS=false
SKIP_LOGIN=false

# Optional: after login, open a post and type a single comment.
# By default, comments are submitted directly after text/image are filled.
POST_URL=https://www.facebook.com/61550584116226/posts/122290195820019470/
COMMENT_TEXT=good
COMMENT_IMAGE=
COMMENT_IMAGE_ATTACH_MODE=file
COMMENT_CLIPBOARD_IMAGE_MAX_SIDE=768
COMMENT_TEXT_INPUT_MODE=paste
CONFIRM_BEFORE_COMMENT=false
SUBMIT_COMMENT=true

# Optional: OpenAI-compatible client settings.
OPENAI_ENABLED=true
# Generic OpenAI config. For split providers, keep comments/text on AI_ATTRIBUTION_*
# and put the official image key under OPENAI_IMAGE_API_KEY.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_WIRE_API=responses
OPENAI_TEXT_MODEL=gpt-5.5
OPENAI_TEXT_FALLBACK_TO_IMAGE_KEY=true
OPENAI_TEXT_FALLBACK_MODEL=gpt-5.5
OPENAI_TEXT_FALLBACK_WIRE_API=responses
OPENAI_TEXT_FALLBACK_BASE_URL=https://api.openai.com/v1
OPENAI_TIMEOUT_MS=180000
# env uses HTTP_PROXY/HTTPS_PROXY for OpenAI API calls; set to direct to bypass them.
OPENAI_PROXY_MODE=env
# Image generation can be routed separately. env means image generation uses HTTP_PROXY/HTTPS_PROXY.
OPENAI_IMAGE_PROXY_MODE=env

# Official OpenAI Images API config.
OPENAI_IMAGE_API_KEY=
OPENAI_IMAGE_BASE_URL=https://api.openai.com/v1
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_EDIT_MODEL=gpt-image-2

# Optional image endpoint adapter:
# images = call the OpenAI-compatible /images/generations endpoint only.
# custom = call OPENAI_IMAGE_ENDPOINT_URL/PATH plus OPENAI_IMAGE_PAYLOAD_JSON only.
OPENAI_IMAGE_API=images
OPENAI_IMAGE_ENDPOINT_URL=
OPENAI_IMAGE_ENDPOINT_PATH=/images/generations
OPENAI_IMAGE_EDIT_ENDPOINT_URL=
OPENAI_IMAGE_EDIT_ENDPOINT_PATH=/images/edits
OPENAI_IMAGE_REFERENCE_ENABLED=true
OPENAI_IMAGE_REFERENCE_FIELD=image[]
OPENAI_IMAGE_REFERENCE_LIMIT=2
OPENAI_IMAGE_REFERENCE_MAX_SIDE=1024
OPENAI_IMAGE_REFERENCE_JPEG_QUALITY=85
OPENAI_IMAGE_EDIT_RETRIES=3
# Example custom payload:
# OPENAI_IMAGE_PAYLOAD_JSON={"model":"{model}","prompt":"{prompt}","size":"{size}"}

# If you use the same relay variables as shoplazza-blacklist-service,
# this project can read AI_ATTRIBUTION_* directly as fallback config.
# AI_ATTRIBUTION_ENABLED=true
# AI_ATTRIBUTION_API_KEY=your_relay_key
# AI_ATTRIBUTION_BASE_URL=http://47.253.224.99:3000/openai
# AI_ATTRIBUTION_MODEL=gpt-5.5
# AI_ATTRIBUTION_WIRE_API=responses
# AI_ATTRIBUTION_TIMEOUT_MS=30000

# Optional: extract the post content and ask OpenAI to draft a comment.
# AI-generated comments are submitted directly unless you change SUBMIT_COMMENT/CONFIRM_BEFORE_COMMENT.
AI_COMMENT=false
AI_COMMENT_LANGUAGE=the same language as the post
AI_COMMENT_STYLE=更随意一点，像平时聊天；可以自然用 it / this / that，不用刻意说产品名；不要用 The/the 开头；不要直接使用链接或标题里的关键词；偏好“好看 & 实用 / pretty & useful / cute & practical”这种短而有力的评价；表情由程序本地追加；别写成 slogan
# Emoji is appended locally to avoid relay/Selenium mojibake like ð���.
# heart uses heart symbols; modern uses face/person-style emoji if your Facebook paste supports them.
AI_COMMENT_EMOJI_ENABLED=true
AI_COMMENT_EMOJI_MODE=modern
# Optional: only add real experience facts here. If empty, the script will not claim received/used/family praise.
AI_COMMENT_EXPERIENCE_NOTES=
# Optional: use ||, semicolons, newlines, or a JSON array to add custom random angles.
AI_COMMENT_ANGLES=好看 & 实用||pretty & useful||cute & practical||nice & easy||looks handy||I'd put it by the door||my mom would like this||家里人应该会喜欢||我会放门口||放阳台应该挺顺眼

# Optional: extract the product link from the post, read the product page,
# then generate a praising comment plus a product use-case image.
AI_PRODUCT_PROMO=false
PRODUCT_URL=
PRODUCT_USE_CASES=home office, daily life, gifting, travel

# Optional: generate an image from an explicit prompt or from the post content.
IMAGE_PROMPT=
AI_IMAGE_FROM_POST=false
AI_IMAGE_STYLE=exact landing-page product match, new background, realistic customer phone photo, no people, no background blur, casual lived-in setting, natural light
IMAGE_OUTPUT=generated/post_image.png
OPENAI_IMAGE_SIZE=1024x1024
OPENAI_IMAGE_QUALITY=low
OPENAI_IMAGE_OUTPUT_FORMAT=jpeg
HTTP_PROXY=http://127.0.0.1:8118
HTTPS_PROXY=http://127.0.0.1:8118
http_proxy=http://127.0.0.1:8118
https_proxy=http://127.0.0.1:8118
# Optional: Docker cannot use host 127.0.0.1 proxy directly. Use these when needed.
# DOCKER_HTTP_PROXY=http://host.docker.internal:8118
# DOCKER_HTTPS_PROXY=http://host.docker.internal:8118
NO_PROXY=localhost,127.0.0.1,::1
no_proxy=localhost,127.0.0.1,::1

# Optional: proxy used by Selenium Chrome. Use this for authenticated datacenter/mobile proxies.
# HTTP_PROXY/HTTPS_PROXY only covers Python network calls; Chrome needs these settings too.
# To avoid Chrome proxy credential popups, set UPSTREAM_HTTP_PROXY to the authenticated
# proxy and point HTTP_PROXY/HTTPS_PROXY/CHROME_PROXY_* at the local forwarder.
UPSTREAM_HTTP_PROXY=
CHROME_PROXY_SCHEME=http
CHROME_PROXY_HOST=
CHROME_PROXY_PORT=
CHROME_PROXY_USERNAME=
CHROME_PROXY_PASSWORD=
CHROME_PROXY_BYPASS=localhost,127.0.0.1,::1
COMMENT_POST_SUBMIT_WAIT_SECONDS=20
COMMENT_BEFORE_SUBMIT_WAIT_SECONDS=5
